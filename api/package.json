{
  "name": "tournament-tracker-api",
  "version": "3.0.0",
  "description": "Tournament Tracker backend",
  "main": "src/server.ts",
  "scripts": {
    "start:local": "export NODE_ENV=production; node ./dist/server.js",
    "start": "podman run --name tournament-tracker-api -p 9090:9090 -v ~/.postgresql:/home/appuser/.postgresql:Z,ro tournament-tracker-api",
    "stop": "podman stop tournament-tracker-api; podman rm tournament-tracker-api",
    "dev": "export NODE_ENV=development; nodemon --watch src --ext ts,js,json src/server.ts",
    "build:local": "tsc -b src && cp src/db/sql/*.sql dist/db/sql/",
    "build": "podman build -t tournament-tracker-api .",
    "sync": "ts-node src/config/exportToClient.ts",
    "devdb": "cockroach start-single-node --insecure --store=path=\"$PWD/cockroach-data\" --listen-addr=localhost:36257 --sql-addr=localhost:26257 --http-addr=localhost:9095",
    "test": "jest",
    "initdb": "./src/config/initDB.sh --host=localhost:26257 --user=root --database=defaultdb --insecure",
    "clean": "podman image prune -a -f"
  },
  "config": {
    "port": "9090"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bathtaters/tournament-tracker.git"
  },
  "author": "Nick Chirumbolo",
  "license": "CC-BY-NC-SA-4.0",
  "bugs": {
    "url": "https://github.com/bathtaters/tournament-tracker/issues"
  },
  "homepage": "https://github.com/bathtaters/tournament-tracker#readme",
  "dependencies": {
    "child-process": "^1.0.2",
    "connect-pg-simple": "^10.0.0",
    "crypto": "^1.0.1",
    "express": "^5.1.0",
    "express-session": "^1.18.0",
    "express-validator": "^7.0.1",
    "morgan": "^1.10.0",
    "pg": "^8.7.3",
    "pg-connection-string": "^2.6.4",
    "postgres-interval": "^4.0.0",
    "prompt": "^1.3.0",
    "validator": "^13.6.0"
  },
  "devDependencies": {
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express": "^5.0.3",
    "@types/express-session": "^1.18.0",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/validator": "^13.12.0",
    "jest": "^30.0.2",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  }
}
